{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ketamine",
  "scopeName": "source.ketamine",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#function_decl" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "begin": "//", "end": "$", "name": "comment.line.double-slash.ketamine" },
        { "begin": "/\\*", "end": "\\*/", "name": "comment.block.ketamine" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ketamine",
      "begin": "\"",
      "end": "\"",
      "patterns": [{ "match": "\\\\[nrt0\"\\\\]", "name": "constant.character.escape.ketamine" }]
    },
    "numbers": {
      "patterns": [
        { "match": "\\b0[xX][0-9a-fA-F_]+\\b", "name": "constant.numeric.hex.ketamine" },
        { "match": "\\b0[bB][01_]+\\b", "name": "constant.numeric.binary.ketamine" },
        { "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b", "name": "constant.numeric.float.ketamine" },
        { "match": "\\b[0-9][0-9_]*\\b", "name": "constant.numeric.integer.ketamine" }
      ]
    },
    "keywords": {
      "patterns": [{
        "match": "\\b(fn|let|mut|return|if|else|while|for|in|loop|break|continue|struct|enum|impl|match|trait|where|pub|use|mod|import|as|static|extern|unsafe|true|false|null|type|self|super|async|await|yield|ref|move|override|abstract|final|macro|inline|checked|unchecked|delegate)\\b",
        "name": "keyword.control.ketamine"
      }]
    },
    "types": {
      "patterns": [{
        "match": "\\b(int|float|bool|str|void|byte|char|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|never|auto|Self)\\b",
        "name": "storage.type.ketamine"
      }]
    },
    "operators": {
      "patterns": [{
        "match": "(->|=>|\\|>|\\.\\.|\\.\\.=|\\+\\+|--|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=|==|!=|<=|>=|<|>|\\+|-|\\*|/|%|&|\\||\\^|~|!|<<|>>|\\.\\.)",
        "name": "keyword.operator.ketamine"
      }]
    },
    "function_decl": {
      "patterns": [{
        "begin": "\\bfn\\s+",
        "beginCaptures": { "0": { "name": "keyword.control.ketamine" } },
        "end": "[(]",
        "endCaptures": { "0": { "name": "punctuation.definition.parameters.ketamine" } },
        "name": "meta.function.ketamine",
        "patterns": [{ "match": "[a-zA-Z_][a-zA-Z0-9_]*", "name": "entity.name.function.ketamine" }]
      }]
    }
  }
}
